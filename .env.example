# ── IA ────────────────────────────────────────────────────────────
# Provedor de IA: claude | openai | gemini | ollama (só "claude" implementado)
AI_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5

# ── Usuário ───────────────────────────────────────────────────────
USER_NAME=Roberto
TZ=America/Sao_Paulo

# ── Agenda (Google Calendar) ──────────────────────────────────────
# Google Calendar → Configurações → seu calendário →
# "Endereço secreto no formato iCal" → cole a URL .ics aqui
CALENDAR_ICS_URL=

# ── Cron / atualização ────────────────────────────────────────────
# Horário da geração diária (padrão: 06:00 no fuso TZ)
CRON_SCHEDULE=0 6 * * *
# Gera o briefing na inicialização caso ainda não exista o do dia
AUTO_GENERATE_ON_BOOT=true
# Segredo para chamar POST /api/refresh manualmente
CRON_SECRET=troque-por-um-segredo-forte

# ── Persistência ──────────────────────────────────────────────────
# Diretório dos JSONs (no Docker é um volume montado em /app/data)
DATA_DIR=./data

# ── Deploy (Traefik já existente na VPS) ──────────────────────────
DOMAIN=briefing.nico.dev.br

# ── Autenticação (login por código de 6 dígitos) ───────────────────
# Segredo usado para assinar o cookie de sessão JWT. Gere com:
# openssl rand -base64 33
AUTH_SECRET=
# Necessário atrás de proxy reverso (Traefik já configurado na VPS)
AUTH_TRUST_HOST=true
# Único email que pode logar
AUTH_EMAIL=seu-email@gmail.com

# ── Resend (envio do código por e-mail) ─────────────────────────────
RESEND_API_KEY=
RESEND_FROM=briefing@seu-dominio.com

# ── Cloudflare Turnstile (captcha invisível no login) ───────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
