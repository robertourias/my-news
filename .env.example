# ── IA ────────────────────────────────────────────────────────────
# Provedor de IA: claude | openai | gemini | ollama (só "claude" implementado)
AI_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5

# ── Usuário ───────────────────────────────────────────────────────
USER_NAME=Roberto
TZ=America/Sao_Paulo

# ── Agenda (Google Calendar) ──────────────────────────────────────
# Google Calendar → Configurações → seu calendário →
# "Endereço secreto no formato iCal" → cole a URL .ics aqui
CALENDAR_ICS_URL=

# ── Cron / atualização ────────────────────────────────────────────
# Horário da geração diária (padrão: 06:00 no fuso TZ)
CRON_SCHEDULE=0 6 * * *
# Gera o briefing na inicialização caso ainda não exista o do dia
AUTO_GENERATE_ON_BOOT=true
# Segredo para chamar POST /api/refresh manualmente
CRON_SECRET=troque-por-um-segredo-forte

# ── Persistência ──────────────────────────────────────────────────
# Diretório dos JSONs (no Docker é um volume montado em /app/data)
DATA_DIR=./data

# ── Deploy (Traefik já existente na VPS) ──────────────────────────
DOMAIN=briefing.nico.dev.br
